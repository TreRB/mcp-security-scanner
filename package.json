{
  "name": "valtik-mcp-security-scanner",
  "version": "0.1.0",
  "description": "Static audit for Model Context Protocol (MCP) server source. Detects the 5 MCP attack patterns: prompt injection, shell passthrough, unbounded FS, SSRF via fetch tools, credential exposure. Plus supply chain issues.",
